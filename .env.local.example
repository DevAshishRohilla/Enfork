# =============================================
# Enfork — Environment Variables Reference
# Copy this to .env (server) and fill in values
# =============================================

# Server
PORT=3000
FRONTEND_URL=https://yourdomain.com

# MySQL — Hostinger hPanel > Databases > MySQL Databases
DB_HOST=localhost
DB_USER=your_db_username
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Resend — https://resend.com (server-side only, never exposed to browser)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=Contact Form <hello@yourdomain.com>
ADMIN_EMAIL=your@email.com
